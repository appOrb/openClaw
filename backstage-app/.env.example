# GitHub Integration
GITHUB_TOKEN=ghp_your_github_personal_access_token

# Azure Integration
AZURE_CLIENT_ID=f2410d10-07d1-49e2-af61-dba86cc9b441
AZURE_CLIENT_SECRET=your_azure_client_secret
AZURE_TENANT_ID=1b9184b9-e785-4727-a33d-f9526fe07006
AZURE_SUBSCRIPTION_ID=05a43f56-f126-4bf1-bb97-9ca4d91dfcb5

# GitHub OAuth (for authentication)
AUTH_GITHUB_CLIENT_ID=your_github_oauth_client_id
AUTH_GITHUB_CLIENT_SECRET=your_github_oauth_client_secret

# Kubernetes (optional - for AKS integration)
