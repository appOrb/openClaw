# Azure VM connection
VM_IP=                        # public IP assigned after provision.sh runs
VM_USER=azureuser

# GitHub (for OpenClaw developer skills — PR creation, code push)
GITHUB_TOKEN=                 # Personal Access Token with repo + workflow scopes

# GitHub Copilot auth is handled interactively via:
#   openclaw models auth login-github-copilot
# No token needed here — stored by openclaw in ~/.openclaw/

# Paperclip (set after first run of vm-setup.sh)
PAPERCLIP_URL=https://your-domain.com

# Keycloak + oauth2-proxy (login security for Paperclip)
# These are passed to Terraform as sensitive variables (never stored in state).
# See infra/terraform/terraform.tfvars.example for details.
KEYCLOAK_ADMIN_PASSWORD=      # Admin password for Keycloak master realm (≥8 chars)
KEYCLOAK_CLIENT_SECRET=       # OIDC client secret: uuidgen
OAUTH2_PROXY_COOKIE_SECRET=   # 32-byte base64 cookie secret: openssl rand -base64 32 | tr -d '\n'
