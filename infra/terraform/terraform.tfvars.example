# Copy this to terraform.tfvars and fill in your values.
# Never commit terraform.tfvars — it is already in .gitignore.

prefix               = "openclaw"
location             = "eastus"
environment          = "production"
vm_size              = "Standard_B2s"
admin_username       = "azureuser"
ssh_public_key_path  = "~/.ssh/id_rsa.pub"
ssh_private_key_path = "~/.ssh/id_rsa"

# Pick a globally unique label for your public IP's FQDN:
# Result: openclaw-<suffix>.eastus.cloudapp.azure.com
dns_label = "openclaw-yourname"

# Restrict SSH to your own IP for security (recommended):
# ssh_source_cidr = "YOUR_PUBLIC_IP/32"
ssh_source_cidr = "*"

# GitHub PAT for OpenClaw (Alex) to push code and open PRs.
# Required scopes: repo, workflow
# Get one at: https://github.com/settings/tokens
# This is marked sensitive — never written to state or logs.
github_token = "ghp_REPLACE_ME"

# Classic GitHub PAT with 'copilot' scope — used by OpenClaw to call GitHub Copilot API.
# Create at: https://github.com/settings/tokens/new?scopes=copilot
# Must be a CLASSIC PAT (ghp_...), not a fine-grained token.
# Leave empty ("") to skip — you can then authenticate manually via:
#   ssh azureuser@VM openclaw models auth login-github-copilot
copilot_pat = ""

# Classic GitHub PAT for gh CLI on the VM — used by agents to clone/push to org repos.
# Required scopes: repo, workflow, read:org
# Create at: https://github.com/settings/tokens/new?scopes=repo,workflow,read:org
# Must be a CLASSIC PAT (ghp_...), not a fine-grained token.
# Leave empty ("") to skip — run infra/vm-auth-setup.sh manually after provisioning.
github_agent_pat = ""

# ── Keycloak + oauth2-proxy (Login Security) ─────────────────────────────────
# Keycloak is the Identity Provider (IdP) that protects the Paperclip dashboard.
# oauth2-proxy sits between Nginx and Paperclip, requiring a valid Keycloak login.

# Admin password for the Keycloak master realm (≥ 8 characters).
# Access the admin console via SSH tunnel:
#   ssh -L 8080:localhost:8080 azureuser@VM_IP
#   Then open: http://localhost:8080/admin
keycloak_admin_password = "REPLACE_ME_strong_password"

# OIDC client secret for the Paperclip client in Keycloak.
# Use a random UUID: uuidgen
keycloak_client_secret = "REPLACE_ME_uuid_here"

# Cookie encryption secret for oauth2-proxy.
# Generate 32 random bytes and base64-encode them: openssl rand -base64 32
oauth2_proxy_cookie_secret = "REPLACE_ME_base64_32bytes"
